# e-flux OAuth credentials
EFLUX_OAUTH_CLIENT_ID=your-client-id
EFLUX_OAUTH_CLIENT_SECRET=your-client-secret

# The base URL of this app (used to construct the OAuth callback URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenID Connect discovery URL
EFLUX_OIDC_DISCOVERY_URL=https://api.public.road.dev/1/marketplace/oauth/e-flux/.well-known/openid-configuration

# Road API base URL
EFLUX_API_BASE_URL=https://api.public.road.dev
