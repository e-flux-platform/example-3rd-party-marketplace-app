# Road OAuth credentials
ROAD_OAUTH_CLIENT_ID=your-client-id
ROAD_OAUTH_CLIENT_SECRET=your-client-secret

# The base URL of this app (used to construct the OAuth callback URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenID Connect discovery URL
ROAD_OIDC_DISCOVERY_URL=https://api.road.io/1/marketplace/oauth/__PROVIDER_SLUG__/.well-known/openid-configuration

# Road API base URL
ROAD_API_BASE_URL=https://api.road.io

# Road provider identifier (sent as the "Provider" header on ERE requests)
ROAD_PROVIDER_ID=__PROVIDER_ID__
