# Both client modes are available at runtime and chosen from the UI on the home
# page — there is no environment switch. The preregistered card is enabled only
# when the credentials below are set; the dynamic (self-registration) card is
# always available.

# Road OAuth credentials — enable the "preregistered" (confidential) card.
# Leave unset to offer only dynamic self-registration.
ROAD_OAUTH_CLIENT_ID=your-client-id
ROAD_OAUTH_CLIENT_SECRET=your-client-secret

# Dynamic (self-registration) options
# Human-readable name sent at registration and shown on the consent screen.
ROAD_OAUTH_CLIENT_NAME=e-flux Reference App (dynamic)
# Optional self-asserted metadata.
# ROAD_OAUTH_CLIENT_URI=https://example.com
# ROAD_OAUTH_LOGO_URI=https://example.com/logo.png
# Where the registration (client_id + management token) is persisted.
# Defaults to ./.dcr-registration.json
# ROAD_OAUTH_REGISTRATION_STORE=./.dcr-registration.json

# The base URL of this app (used to construct the OAuth callback URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenID Connect discovery URL
ROAD_OIDC_DISCOVERY_URL=https://api.road.io/1/marketplace/oauth/__PROVIDER_SLUG__/.well-known/openid-configuration

# Road API base URL
ROAD_API_BASE_URL=https://api.road.io

# Road provider identifier (sent as the "Provider" header on ERE requests)
ROAD_PROVIDER_ID=__PROVIDER_ID__
